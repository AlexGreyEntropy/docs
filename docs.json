{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Thaler Finance",
  "colors": {
    "primary": "#000000",
    "light": "#ffffff",
    "dark": "#000000"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Introduction",
            "pages": ["index"]
          },
          {
            "group": "Overview",
            "pages": [
              "overview/what-is-thaler",
              "overview/architecture",
              "overview/custody-and-policy"
            ]
          },
          {
            "group": "Strategies",
            "pages": [
              "strategies/index",
              "strategies/liquid-staking",
              "strategies/lending-markets",
              "strategies/perpetual-markets"
            ]
          },
          {
            "group": "Vault lifecycle",
            "pages": [
              "vault/create",
              "vault/claim",
              "vault/close",
              "vault/fees"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/principal-protection",
              "security/yield-floor",
              "security/risk-disclosure"
            ]
          },
          {
            "group": "Help",
            "pages": ["faq"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://thaler.finance",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "X / Twitter",
          "href": "https://twitter.com/ThalerFinance",
          "icon": "twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@thaler.finance"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://thaler.finance"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/ThalerFinance",
      "github": "https://github.com/Thaler-Foundation"
    }
  }
}
